# Vercel AI Gateway (streaming /ai/summary). En Vercel suele autenticar por OIDC sin clave.
# Local: creá clave en https://vercel.com/dashboard → AI Gateway
AI_GATEWAY_API_KEY=
# Modelo vía gateway (plan gratuito / bajo costo). Ejemplos: google/gemini-2.0-flash, mistral/ministral-8b-latest
AI_GATEWAY_MODEL=google/gemini-2.0-flash

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mercado Libre OAuth Credentials
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
# Set to false only if your ML app does not use PKCE (S256). Default is PKCE enabled.
# MELI_USE_PKCE=true

# Secret for signing JWT cookies
JWT_SECRET=
