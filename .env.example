# Cursor / local: copiá este archivo a `.env` o `.env.local` en la raíz (`.env.local` pisa valores de `.env`).

# --- IA resumen (/ai/summary) ---
# Backend por defecto: Gemini directo (recomendado si Vercel AI Gateway pide tarjeta).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Forzar backend: gemini | gateway
# AI_SUMMARY_BACKEND=gemini

# Vercel AI Gateway (solo con AI_SUMMARY_BACKEND=gateway). Usá exactamente:
# AI_GATEWAY_API_KEY=tu_clave_del_gateway
# Formato de modelo: proveedor/modelo (ej. openai/gpt-4o-mini). Si usás dos puntos, se corrige a barra.
# AI_GATEWAY_MODEL=openai/gpt-4o-mini
# AI_GATEWAY_MODEL=google/gemini-2.0-flash

# OpenAI directo NO está cableado en este servidor; con Gateway pedís modelos openai/* con la clave del gateway.
# Si en el futuro agregás @ai-sdk/openai, ahí sí tendría sentido OPENAI_API_KEY.

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Mercado Libre OAuth Credentials
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
# MELI_USE_PKCE=true

JWT_SECRET=
